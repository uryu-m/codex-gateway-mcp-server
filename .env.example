# ============================================================================
# Codex Gateway MCP - Environment Variables (sample)
# ============================================================================
# Copy this file to `.env` and adjust values for your environment.
# All variables are optional - sensible defaults are applied if unset.

# ----- Codex CLI -----

# Path to the codex executable. Defaults to looking up "codex" in $PATH.
# CODEX_BIN=/Users/uryu-mitsutaka/.codex/bin/codex

# Default Codex sandbox mode. One of: read-only | workspace-write | danger-full-access
# `workspace-write` is the recommended default (writes only within the project).
CODEX_SANDBOX=workspace-write

# Default Codex approval policy. One of: never | on-request | on-failure | untrusted
CODEX_APPROVAL=on-request

# Default Codex model (optional). Tool-level `model` input takes precedence.
# If unset, Codex uses its configured default.
# CODEX_MODEL=gpt-5.5

# Timeout in seconds for a single codex_implement call.
CODEX_TIMEOUT_SECONDS=600

# ----- Gateway behavior -----

# Project root that the gateway treats as the working directory.
# If unset, the directory the server was launched from is used.
# PROJECT_ROOT=/Users/uryu-mitsutaka/PythonProjects/presentation-system

# Where audit logs are written.
LOG_DIR=./logs

# Set to "1" to print verbose debug info to stderr.
DEBUG=0
