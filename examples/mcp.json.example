{
  "_comment": "Copy this file to <your-project>/.mcp.json (or merge into ~/.claude.json) and edit absolute paths.",
  "mcpServers": {
    "codex-gateway": {
      "command": "node",
      "args": [
        "/absolute/path/to/codex-gateway-mcp/dist/index.js"
      ],
      "env": {
        "PROJECT_ROOT": "/absolute/path/to/your/target-repo",
        "LOG_DIR": "/absolute/path/to/your/target-repo/logs/codex",
        "CODEX_SANDBOX": "workspace-write",
        "CODEX_APPROVAL": "on-request",
        "CODEX_TIMEOUT_SECONDS": "600"
      }
    }
  }
}
